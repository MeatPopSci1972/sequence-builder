[{"n":1,"l":"#!/usr/bin/env node"},{"n":2,"l":"// ═══════════════════════════════════════════════════════════════"},{"n":3,"l":"//  SequenceForge — build.js"},{"n":4,"l":"//  Syncs sequence-builder.store.js → sequence-builder.html"},{"n":5,"l":"//"},{"n":6,"l":"//  What it does:"},{"n":7,"l":"//    1. Reads sequence-builder.store.js"},{"n":8,"l":"//    2. Strips the CommonJS export block (module.exports = { ... })"},{"n":9,"l":"//    3. Strips the trailing comment that precedes it"},{"n":10,"l":"//    4. Splices the result into sequence-builder.html between:"},{"n":11,"l":"//         // @@STORE-START"},{"n":12,"l":"//         // @@STORE-END"},{"n":13,"l":"//    5. Writes sequence-builder.html in place"},{"n":14,"l":"//"},{"n":15,"l":"//  Usage:"},{"n":16,"l":"//    node build.js"},{"n":17,"l":"//"},{"n":18,"l":"//  Gate (run after build):"},{"n":19,"l":"//    node build.js && \\"},{"n":20,"l":"//    sed -n '/<script>/,/<\\/script>/p' sequence-builder.html \\"},{"n":21,"l":"//      | sed '1s/<script>//' | sed '$s/<\\/script>//' > sf-script.js && \\"},{"n":22,"l":"//    node --check sf-script.js && \\"},{"n":23,"l":"//    node sequence-builder.test.js"},{"n":24,"l":"//"},{"n":25,"l":"//  Zero dependencies. Node 14+."},{"n":26,"l":"// ═══════════════════════════════════════════════════════════════"},{"n":27,"l":""},{"n":28,"l":"'use strict'"},{"n":29,"l":""},{"n":30,"l":"const fs = require('fs')"},{"n":31,"l":"const path = require('path')"},{"n":32,"l":""},{"n":33,"l":"// ── Paths ────────────────────────────────────────────────────"},{"n":34,"l":"const ROOT = path.dirname(__filename)"},{"n":35,"l":"const STORE_SRC = path.join(ROOT, 'sequence-builder.store.js')"},{"n":36,"l":"const HTML_SRC = path.join(ROOT, 'sequence-builder.html')"},{"n":37,"l":""},{"n":38,"l":"const SENTINEL_START = '// @@STORE-START'"},{"n":39,"l":"const SENTINEL_END = '// @@STORE-END'"},{"n":40,"l":""},{"n":41,"l":"// ── Read sources ─────────────────────────────────────────────"},{"n":42,"l":"if (!fs.existsSync(STORE_SRC)) fatal(`Store source not found: ${STORE_SRC}`)"},{"n":43,"l":"if (!fs.existsSync(HTML_SRC)) fatal(`HTML target not found:  ${HTML_SRC}`)"},{"n":44,"l":""},{"n":45,"l":"const storeRaw = fs.readFileSync(STORE_SRC, 'utf8')"},{"n":46,"l":"const htmlRaw = fs.readFileSync(HTML_SRC, 'utf8')"},{"n":47,"l":""},{"n":48,"l":"// ── Validate sentinels ───────────────────────────────────────"},{"n":49,"l":"const startIdx = htmlRaw.indexOf(SENTINEL_START)"},{"n":50,"l":"const endIdx = htmlRaw.indexOf(SENTINEL_END)"},{"n":51,"l":""},{"n":52,"l":"if (startIdx === -1) fatal(`Sentinel not found in HTML: ${SENTINEL_START}`)"},{"n":53,"l":"if (endIdx === -1) fatal(`Sentinel not found in HTML: ${SENTINEL_END}`)"},{"n":54,"l":"if (startIdx >= endIdx) fatal('@@STORE-START must appear before @@STORE-END')"},{"n":55,"l":""},{"n":56,"l":"const startCount = (htmlRaw.match(/\\/\\/ @@STORE-START/g) || []).length"},{"n":57,"l":"const endCount = (htmlRaw.match(/\\/\\/ @@STORE-END/g) || []).length"},{"n":58,"l":"if (startCount !== 1) fatal(`Expected exactly 1 @@STORE-START, found ${startCoun"},{"n":59,"l":"if (endCount !== 1) fatal(`Expected exactly 1 @@STORE-END, found ${endCount}`)"},{"n":60,"l":""}]