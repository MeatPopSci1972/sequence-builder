# =================================================================
# sequence-builder — .gitattributes
# Enforce LF everywhere, protect binaries, clean up diffs/archives
# =================================================================

# Default: auto-detect text, normalise to LF on commit + checkout
* text=auto eol=lf

# ── Source files ──────────────────────────────────────────────
*.html      text eol=lf diff=html
*.js        text eol=lf
*.json      text eol=lf diff=json
*.md        text eol=lf diff=markdown
*.txt       text eol=lf

# ── Config / tooling ─────────────────────────────────────────
*.ps1          text eol=crlf
.gitattributes text eol=lf
.gitignore     text eol=lf
.prettierrc    text eol=lf
package.json   text eol=lf
package-lock.json text eol=lf

# ── Binary — never diff, never mangle line endings ───────────
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.zip    binary
*.node   binary

# ── Export-ignore — excluded from git archive / release zips ─
.gitattributes     export-ignore
.gitignore         export-ignore
.prettierrc        export-ignore
package-lock.json  export-ignore
launcher.js        export-ignore
sf-preflight.ps1   export-ignore
sf-server.js       export-ignore
sf-endpoints.js    export-ignore
sf-readme-gen.js   export-ignore
build.js           export-ignore
lint.js            export-ignore
*.test.js          export-ignore
*-test.html        export-ignore
test-snapshots/    export-ignore
dev/               export-ignore
docs/              export-ignore
releases/**/*.html -text
